{
  "expo": {
    "name": "GlassCount",
    "slug": "drink-tracking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "drink-tracking",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.drinktracking.app",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.drinktracking.app",
      "minSdkVersion": 26
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "./plugins/remove-ipad-orientations",
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#ffffff"
        }
      ],
      "expo-localization",
      [
        "@sentry/react-native",
        {
          "organization": "software-entwicklung-rene",
          "project": "react-native",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "908af51d-82f0-460e-b41e-286e7d1ca07d"
      }
    }
  }
}
