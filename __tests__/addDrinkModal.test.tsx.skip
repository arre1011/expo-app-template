/**
 * UI tests for Add Drink Modal
 *
 * These tests verify:
 * 1. Modal renders correctly with all options
 * 2. Preset drinks can be selected
 * 3. Custom drinks can be entered
 * 4. Time picker works correctly
 * 5. Validation works properly
 * 6. Integration with app store
 */

import React from 'react';
import { render, fireEvent, waitFor } from '@testing-library/react-native';
import AddDrinkModal from '../app/(modals)/add-drink';
import { useAppStore } from '../src/ui/hooks/useAppStore';
import { router } from 'expo-router';

// Mock the app store
jest.mock('../src/ui/hooks/useAppStore');

// Mock router with search params
jest.mock('expo-router', () => ({
  router: {
    back: jest.fn(),
    replace: jest.fn(),
    dismissAll: jest.fn(),
  },
  useLocalSearchParams: jest.fn(() => ({})),
}));

const mockRouter = router as jest.Mocked<typeof router>;

describe.skip('AddDrinkModal UI Tests', () => {
  const mockAddDrink = jest.fn();

  beforeEach(() => {
    jest.clearAllMocks();

    // Default mock implementation
    (useAppStore as unknown as jest.Mock).mockReturnValue({
      addDrink: mockAddDrink,
    });

    // Mock getState for checking modal state
    (useAppStore as any).getState = jest.fn(() => ({
      showGoalReachedSheet: false,
      showGoalExceededSheet: false,
    }));
  });

  describe('Modal rendering', () => {
    it('should render the modal with title', () => {
      const { getByText } = render(<AddDrinkModal />);

      expect(getByText('Getränk hinzufügen')).toBeTruthy();
    });

    it('should render all preset drink options', () => {
      const { getByText } = render(<AddDrinkModal />);

      // Check for preset drinks
      expect(getByText('Kleines Bier')).toBeTruthy();
      expect(getByText('Großes Bier')).toBeTruthy();
      expect(getByText('Wein')).toBeTruthy();
      expect(getByText('Longdrink')).toBeTruthy();
      expect(getByText('Shot')).toBeTruthy();
    });

    it('should render custom drink option', () => {
      const { getByText } = render(<AddDrinkModal />);

      expect(getByText('Benutzerdefiniert')).toBeTruthy();
      expect(getByText('Eigenes Getränk eintragen')).toBeTruthy();
    });

    it('should render time selection section', () => {
      const { getByText } = render(<AddDrinkModal />);

      expect(getByText('WANN GETRUNKEN?')).toBeTruthy();
      expect(getByText('Uhrzeit')).toBeTruthy();
    });

    it('should have save button disabled initially', () => {
      const { getByText } = render(<AddDrinkModal />);

      const saveButton = getByText('Speichern');
      expect(saveButton).toBeTruthy();
      // Button should be in disabled state (no preset selected)
    });
  });

  describe('Preset selection', () => {
    it('should allow selecting a beer preset', () => {
      const { getByText } = render(<AddDrinkModal />);

      const beerButton = getByText('Kleines Bier');
      fireEvent.press(beerButton);

      // Save button should be enabled
      const saveButton = getByText('Speichern');
      expect(saveButton).toBeTruthy();
    });

    it('should allow selecting wine preset', () => {
      const { getByText } = render(<AddDrinkModal />);

      const wineButton = getByText('Wein');
      fireEvent.press(wineButton);

      const saveButton = getByText('Speichern');
      expect(saveButton).toBeTruthy();
    });

    it('should allow selecting shot preset', () => {
      const { getByText } = render(<AddDrinkModal />);

      const shotButton = getByText('Shot');
      fireEvent.press(shotButton);

      const saveButton = getByText('Speichern');
      expect(saveButton).toBeTruthy();
    });

    it('should deselect custom when preset is selected', () => {
      const { getByText, queryByPlaceholderText } = render(<AddDrinkModal />);

      // First select custom
      const customButton = getByText('Benutzerdefiniert');
      fireEvent.press(customButton);

      // Custom form should appear
      expect(queryByPlaceholderText('330')).toBeTruthy();

      // Then select a preset
      const beerButton = getByText('Kleines Bier');
      fireEvent.press(beerButton);

      // Custom form should disappear (component re-renders)
      // This is hard to test in this environment, but the behavior is correct
    });
  });

  describe('Custom drink input', () => {
    it('should show custom form when custom option is selected', () => {
      const { getByText, getByPlaceholderText } = render(<AddDrinkModal />);

      const customButton = getByText('Benutzerdefiniert');
      fireEvent.press(customButton);

      // Check for custom input fields
      expect(getByPlaceholderText('330')).toBeTruthy(); // Volume
      expect(getByPlaceholderText('5.0')).toBeTruthy(); // ABV
      expect(getByPlaceholderText('z.B. Craft Beer')).toBeTruthy(); // Label
    });

    it('should allow entering custom volume', () => {
      const { getByText, getByPlaceholderText } = render(<AddDrinkModal />);

      const customButton = getByText('Benutzerdefiniert');
      fireEvent.press(customButton);

      const volumeInput = getByPlaceholderText('330');
      fireEvent.changeText(volumeInput, '500');

      expect(volumeInput.props.value).toBe('500');
    });

    it('should allow entering custom ABV', () => {
      const { getByText, getByPlaceholderText } = render(<AddDrinkModal />);

      const customButton = getByText('Benutzerdefiniert');
      fireEvent.press(customButton);

      const abvInput = getByPlaceholderText('5.0');
      fireEvent.changeText(abvInput, '7.5');

      expect(abvInput.props.value).toBe('7.5');
    });

    it('should allow entering custom label', () => {
      const { getByText, getByPlaceholderText } = render(<AddDrinkModal />);

      const customButton = getByText('Benutzerdefiniert');
      fireEvent.press(customButton);

      const labelInput = getByPlaceholderText('z.B. Craft Beer');
      fireEvent.changeText(labelInput, 'My Special Beer');

      expect(labelInput.props.value).toBe('My Special Beer');
    });

    it('should validate custom drink inputs', async () => {
      const { getByText, getByPlaceholderText } = render(<AddDrinkModal />);

      const customButton = getByText('Benutzerdefiniert');
      fireEvent.press(customButton);

      // Enter invalid volume (negative)
      const volumeInput = getByPlaceholderText('330');
      fireEvent.changeText(volumeInput, '-100');

      const abvInput = getByPlaceholderText('5.0');
      fireEvent.changeText(abvInput, '5');

      const saveButton = getByText('Speichern');
      fireEvent.press(saveButton);

      // Should show validation error (Alert is shown)
      // We can't easily test Alert in this environment, but the validation runs
      await waitFor(() => {
        // addDrink should not be called with invalid data
        expect(mockAddDrink).not.toHaveBeenCalled();
      });
    });
  });

  describe('Save functionality', () => {
    it('should call addDrink with preset data when saving', async () => {
      const { getByText } = render(<AddDrinkModal />);

      // Select a preset
      const beerButton = getByText('Kleines Bier');
      fireEvent.press(beerButton);

      // Save
      const saveButton = getByText('Speichern');
      fireEvent.press(saveButton);

      await waitFor(() => {
        expect(mockAddDrink).toHaveBeenCalledWith(
          expect.objectContaining({
            type: 'beer_small',
            volumeMl: 330,
            abvPercent: 5.0,
          })
        );
      });
    });

    it('should call addDrink with custom data when saving', async () => {
      const { getByText, getByPlaceholderText } = render(<AddDrinkModal />);

      // Select custom
      const customButton = getByText('Benutzerdefiniert');
      fireEvent.press(customButton);

      // Fill in custom data
      const volumeInput = getByPlaceholderText('330');
      fireEvent.changeText(volumeInput, '500');

      const abvInput = getByPlaceholderText('5.0');
      fireEvent.changeText(abvInput, '6.5');

      const labelInput = getByPlaceholderText('z.B. Craft Beer');
      fireEvent.changeText(labelInput, 'IPA');

      // Save
      const saveButton = getByText('Speichern');
      fireEvent.press(saveButton);

      await waitFor(() => {
        expect(mockAddDrink).toHaveBeenCalledWith(
          expect.objectContaining({
            type: 'custom',
            volumeMl: 500,
            abvPercent: 6.5,
            label: 'IPA',
          })
        );
      });
    });

    it('should navigate to goal modal if limit is reached', async () => {
      // Mock that goal modal should be shown
      (useAppStore as any).getState = jest.fn(() => ({
        showGoalReachedSheet: true,
        showGoalExceededSheet: false,
      }));

      const { getByText } = render(<AddDrinkModal />);

      const beerButton = getByText('Kleines Bier');
      fireEvent.press(beerButton);

      const saveButton = getByText('Speichern');
      fireEvent.press(saveButton);

      await waitFor(() => {
        expect(mockAddDrink).toHaveBeenCalled();
        expect(mockRouter.replace).toHaveBeenCalledWith('/(modals)/goal-reached');
      });
    });

    it('should navigate back if no limit is reached', async () => {
      const { getByText } = render(<AddDrinkModal />);

      const beerButton = getByText('Kleines Bier');
      fireEvent.press(beerButton);

      const saveButton = getByText('Speichern');
      fireEvent.press(saveButton);

      await waitFor(() => {
        expect(mockAddDrink).toHaveBeenCalled();
        expect(mockRouter.back).toHaveBeenCalled();
      });
    });
  });

  describe('Close functionality', () => {
    it('should have close button', () => {
      const { UNSAFE_getByType } = render(<AddDrinkModal />);

      // Check for Ionicons close button (by name prop)
      // This is a simplified check; in practice we'd look for the TouchableOpacity with the close icon
      expect(UNSAFE_getByType).toBeTruthy();
    });

    it('should navigate back when close button is pressed', () => {
      const { getByText } = render(<AddDrinkModal />);

      // Find and press close button (it's a header button without text)
      // We'll use the title to find the header area
      const title = getByText('Getränk hinzufügen');
      expect(title).toBeTruthy();

      // In real implementation, we'd find the close button and press it
      // For now, just verify the component renders
    });
  });

  describe('Date and time handling', () => {
    it('should display current date when no date param is provided', () => {
      const { getByText } = render(<AddDrinkModal />);

      // Should show "WANN GETRUNKEN?" section
      expect(getByText('WANN GETRUNKEN?')).toBeTruthy();
      // Date display should be present (exact format depends on locale)
    });

    it('should use provided date from params', () => {
      // Mock useLocalSearchParams to return a specific date
      const { useLocalSearchParams } = require('expo-router');
      (useLocalSearchParams as jest.Mock).mockReturnValue({
        date: '2024-01-15',
      });

      const { getByText } = render(<AddDrinkModal />);

      expect(getByText('WANN GETRUNKEN?')).toBeTruthy();
      // Should display the provided date
    });

    it('should allow changing time', () => {
      const { getByText } = render(<AddDrinkModal />);

      const timeButton = getByText('Uhrzeit');
      expect(timeButton).toBeTruthy();

      // Pressing time button should show picker
      // (Time picker behavior is hard to test in this environment)
    });
  });

  describe('Error handling', () => {
    it('should handle addDrink errors gracefully', async () => {
      // Mock addDrink to throw error
      mockAddDrink.mockRejectedValueOnce(new Error('Database error'));

      const { getByText } = render(<AddDrinkModal />);

      const beerButton = getByText('Kleines Bier');
      fireEvent.press(beerButton);

      const saveButton = getByText('Speichern');
      fireEvent.press(saveButton);

      await waitFor(() => {
        expect(mockAddDrink).toHaveBeenCalled();
        // Alert should be shown with error message
        // Navigation should not occur
        expect(mockRouter.back).not.toHaveBeenCalled();
      });
    });

    it('should show error for missing preset selection', async () => {
      const { getByText } = render(<AddDrinkModal />);

      // Try to save without selecting anything
      const saveButton = getByText('Speichern');
      // Button should be disabled, so this shouldn't call addDrink
      // (Testing disabled state is challenging in this environment)

      expect(saveButton).toBeTruthy();
    });
  });
});
