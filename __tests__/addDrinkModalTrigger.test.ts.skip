/**
 * Integration test: Modal Trigger on BAC Limit
 *
 * This test ensures that when a user adds a drink that reaches or exceeds
 * the BAC limit, the goal modal is triggered correctly.
 *
 * CRITICAL: This test verifies that showGoalReachedSheet or showGoalExceededSheet
 * is set to TRUE when the limit is reached.
 */

import { useAppStore } from '../src/ui/hooks/useAppStore';
import {
  createUserProfile,
} from '../src/data/repositories/userProfileRepository';
import {
  upsertDailyGoal,
} from '../src/data/repositories/dailyGoalRepository';
import { getDatabase, resetDatabase } from '../src/data/database/connection';
import { CreateDrinkEntry, UserProfile } from '../src/domain/models/types';
import { format } from 'date-fns';

// Mock expo-router
jest.mock('expo-router', () => ({
  router: {
    back: jest.fn(),
    replace: jest.fn(),
    dismissAll: jest.fn(),
  },
}));

describe('Add Drink - Modal Trigger Tests', () => {
  let testProfile: UserProfile;

  beforeAll(async () => {
    await getDatabase();
  });

  beforeEach(async () => {
    // Reset database
    await resetDatabase();

    // Reset store
    useAppStore.setState({
      profile: null,
      hasProfile: false,
      isProfileLoading: true,
      todayDrinks: [],
      sessionDrinks: [],
      todayGoal: null,
      bacTimeSeries: null,
      isTodayLoading: true,
      isAddDrinkModalOpen: false,
      showGoalReachedSheet: false,
      showGoalExceededSheet: false,
      pendingDrink: null,
    });

    // Create test profile
    testProfile = await createUserProfile({
      weightKg: 75,
      sex: 'male',
      bodyWaterConstantR: 0.68,
      eliminationRatePermillePerHour: 0.15,
    });

    // Set goal to 0.5‰
    await upsertDailyGoal({
      date: format(new Date(), 'yyyy-MM-dd'),
      maxBAC: 0.5,
      enabled: true,
    });

    // Load stores
    await useAppStore.getState().loadProfile();
    await useAppStore.getState().loadTodayData();
  });

  describe('CRITICAL: Modal should be triggered when limit is reached', () => {
    it('should set showGoalReachedSheet to TRUE when BAC reaches limit', async () => {
      const today = new Date();

      // Add first drink (should be under limit)
      const drink1: CreateDrinkEntry = {
        type: 'beer_small',
        volumeMl: 330,
        abvPercent: 5.0,
        label: 'Beer 1',
        notes: null,
        timestamp: new Date(today.getTime() - 60 * 60 * 1000).toISOString(),
      };

      await useAppStore.getState().addDrink(drink1);

      // First drink should not trigger modal
      let state = useAppStore.getState();
      expect(state.showGoalReachedSheet).toBe(false);
      expect(state.showGoalExceededSheet).toBe(false);

      // Add second drink that should trigger limit
      const drink2: CreateDrinkEntry = {
        type: 'beer_small',
        volumeMl: 330,
        abvPercent: 5.0,
        label: 'Beer 2',
        notes: null,
        timestamp: today.toISOString(),
      };

      await useAppStore.getState().addDrink(drink2);

      // CRITICAL TEST: Modal should be shown!
      state = useAppStore.getState();
      const modalShown = state.showGoalReachedSheet || state.showGoalExceededSheet;

      expect(modalShown).toBe(true);
      expect(state.pendingDrink).not.toBeNull();
    });

    it('should set showGoalExceededSheet to TRUE when BAC significantly exceeds limit', async () => {
      const today = new Date();

      // Add multiple drinks to significantly exceed limit
      const timestamps = [
        new Date(today.getTime() - 120 * 60 * 1000).toISOString(),
        new Date(today.getTime() - 90 * 60 * 1000).toISOString(),
        new Date(today.getTime() - 60 * 60 * 1000).toISOString(),
      ];

      // Add first 3 drinks
      for (let i = 0; i < 3; i++) {
        const drink: CreateDrinkEntry = {
          type: 'wine',
          volumeMl: 200,
          abvPercent: 12.0,
          label: `Wine ${i + 1}`,
          notes: null,
          timestamp: timestamps[i],
        };

        await useAppStore.getState().addDrink(drink);

        // Confirm if modal appears
        const state = useAppStore.getState();
        if (state.pendingDrink) {
          await state.confirmPendingDrink();
        }
      }

      // Add 4th drink - should definitely trigger exceeded modal
      const drink4: CreateDrinkEntry = {
        type: 'wine',
        volumeMl: 200,
        abvPercent: 12.0,
        label: 'Wine 4',
        notes: null,
        timestamp: today.toISOString(),
      };

      await useAppStore.getState().addDrink(drink4);

      // CRITICAL TEST: Modal should be shown!
      const state = useAppStore.getState();
      expect(state.showGoalExceededSheet).toBe(true);
      expect(state.pendingDrink).not.toBeNull();
    });

    it('should NOT trigger modal when goal is disabled', async () => {
      const today = new Date();

      // Disable goal
      await upsertDailyGoal({
        date: format(today, 'yyyy-MM-dd'),
        maxBAC: 0.5,
        enabled: false, // 👈 DISABLED
      });

      await useAppStore.getState().loadTodayData();

      // Add multiple drinks that would normally trigger modal
      for (let i = 0; i < 5; i++) {
        const drink: CreateDrinkEntry = {
          type: 'wine',
          volumeMl: 200,
          abvPercent: 12.0,
          label: `Wine ${i + 1}`,
          notes: null,
          timestamp: new Date(today.getTime() - (120 - i * 20) * 60 * 1000).toISOString(),
        };

        await useAppStore.getState().addDrink(drink);

        // Modal should NEVER be shown
        const state = useAppStore.getState();
        expect(state.showGoalReachedSheet).toBe(false);
        expect(state.showGoalExceededSheet).toBe(false);
      }
    });
  });

  describe('Edge cases', () => {
    it('should trigger modal at exact limit threshold', async () => {
      const today = new Date();

      // Calculate exact drink to reach 0.5‰
      // For 75kg male with r=0.68: 0.5‰ = 25.5g alcohol
      // Try to get as close as possible with 2 beers

      const drink1: CreateDrinkEntry = {
        type: 'beer_small',
        volumeMl: 330,
        abvPercent: 5.0,
        label: 'Beer 1',
        notes: null,
        timestamp: new Date(today.getTime() - 60 * 60 * 1000).toISOString(),
      };

      await useAppStore.getState().addDrink(drink1);

      const drink2: CreateDrinkEntry = {
        type: 'beer_small',
        volumeMl: 330,
        abvPercent: 5.0,
        label: 'Beer 2',
        notes: null,
        timestamp: today.toISOString(),
      };

      await useAppStore.getState().addDrink(drink2);

      // Should trigger modal (BAC should be around 0.5‰)
      const state = useAppStore.getState();
      expect(state.showGoalReachedSheet || state.showGoalExceededSheet).toBe(true);
    });

    it('should NOT trigger modal when just under limit', async () => {
      const today = new Date();

      // Add just one small beer - should be well under 0.5‰
      const drink: CreateDrinkEntry = {
        type: 'beer_small',
        volumeMl: 330,
        abvPercent: 5.0,
        label: 'Beer',
        notes: null,
        timestamp: today.toISOString(),
      };

      await useAppStore.getState().addDrink(drink);

      // Should NOT trigger modal
      const state = useAppStore.getState();
      expect(state.showGoalReachedSheet).toBe(false);
      expect(state.showGoalExceededSheet).toBe(false);
      expect(state.pendingDrink).toBeNull();
    });
  });

  describe('Regression test: showGoalReachedSheet must be set to TRUE', () => {
    it('FAILS if showGoalReachedSheet is set to FALSE when limit is reached', async () => {
      const today = new Date();

      // Setup: Add drinks to reach limit
      const drink1: CreateDrinkEntry = {
        type: 'wine',
        volumeMl: 200,
        abvPercent: 12.0,
        label: 'Wine 1',
        notes: null,
        timestamp: new Date(today.getTime() - 60 * 60 * 1000).toISOString(),
      };

      await useAppStore.getState().addDrink(drink1);

      const drink2: CreateDrinkEntry = {
        type: 'wine',
        volumeMl: 200,
        abvPercent: 12.0,
        label: 'Wine 2',
        notes: null,
        timestamp: today.toISOString(),
      };

      await useAppStore.getState().addDrink(drink2);

      // CRITICAL ASSERTION
      const state = useAppStore.getState();

      // This test will FAIL if you changed the code to:
      // set({ pendingDrink: drink, showGoalReachedSheet: false })
      expect(state.showGoalReachedSheet || state.showGoalExceededSheet).toBe(true);

      // Additional checks
      if (state.showGoalReachedSheet === false && state.showGoalExceededSheet === false) {
        throw new Error(
          '🚨 REGRESSION DETECTED: Modal is disabled! ' +
          'showGoalReachedSheet and showGoalExceededSheet are both FALSE when they should be TRUE. ' +
          'Check useAppStore.ts:194-203'
        );
      }
    });
  });
});
