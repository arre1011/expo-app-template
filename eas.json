{
  "cli": {
    "version": ">= 13.2.5",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "production",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "autoIncrement": true
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "ios": {
        "resourceClass": "m-medium"
      },
      "autoIncrement": true
    }
  }
}
